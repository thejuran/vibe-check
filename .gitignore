# Ignore zip files (auto-generated skill packages)
*.zip

# Tool-owned working state (per fork architecture — .turingmind/ is gitignored;
# user cp's REVIEW.md somewhere persistent if they want it tracked)
.turingmind/

# GSD planning artifacts (kept out of the fork repo itself)
.planning/

# Milestone-orchestrator config (release_intent / skip_walkthrough etc.) — local
# operator state, must not drift into the repo as a committed release posture
.orchestrator.json

# Private design docs (spec/plan notes — kept local, not shared)
docs/superpowers/

# Local distribution aids — the prompts to hand a new user, not part of the plugin
SHARE-PROMPT*.md

# macOS Finder metadata
.DS_Store
